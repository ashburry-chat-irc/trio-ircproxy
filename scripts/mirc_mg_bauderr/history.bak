alias -l msg echo >> msg >> $1-

on *:topic:#: {
  var %topic = $strip($1-)
  if (%topic == $null) { return }
  topic_history_add $chan $1-
}
raws 332:*: {
  if ($3 == $null) { return }
  topic_history_add $2 $3-

}
alias topic_history_add {
  var %chan = $1
  if (!%chan) || ($strip($2) == $null) { return }
  var %i = 0
  var %check = $varname_global(topic_history_ $+ %chan,*)
  var %varname
  :loop
  if (%i >= 15) { goto end }
  inc %i
  %varname = $var($eval(%check,1),%i)
  if ([ [ %varname ] ] === $2-) { return }
  if (!%varname) { goto end }
  goto loop
  :end
  set $varname_global(topic_history_ $+ %chan,$ctime) $2-

}
alias topic_history_popup {
  if ($1 == begin) {
    topic_history_add $$chan $chan($chan).topic
  }
  if ($1 == end) { return }
  if ($1 > 15) { return }
  var %chan = $chan
  if (!%chan) || (!$1) { return }
  var %check = $varname_global(topic_history_ $+ %chan,*)
  ; eval is set to 1 because it gets evaled when displayed
  var %topic = $var($eval(%check,1),$1)
  if (%topic == $null) { return }
  var %top-pop = $strip($eval(%topic,2))
  if ($len(%top-pop) > 60) { %top-pop = $left(%top-pop, 58) ... }
  %top-pop = $replace(%top-pop,$,$chr(36) $+ !)
  return $replace(%top-pop,:,$chr(58))) : /editbox /topic %chan $eval(%topic,1)
}
