; Below are variable names with an white-space then an value to each var name.
; If you are creating an script, do not uise variables starting with %bde_
; %bde_ variables should be used by MG script only,or you may end up breaking both scripts.
;;
%bde_glob_python3!file_path C:\Users\USER\AppData\Local\Programs\Python\Python310\python.exe
%bde_glob_use-port!proxy 4321
%bde_glob_use-port!http 80
%bde_glob_python!none C:\Users\USER\AppData\Local\Programs\Python\Python310\python.exe
%bde_glob_oper-scan-join!Rizon $true
